---
// Experience.astro
---
<section id="experience" class="relative space-y-16 pt-8 pb-12">
  <!-- Drifting Background Title -->
  <div class="kinetic-heading text-gray-200 dark:text-white/[0.04] absolute top-0 left-0">TIMELINE</div>

  <h3 class="text-2xl font-bold font-jetbrains tracking-tight section-reveal relative z-10">Education & Experience<span class="text-cyber-citrus">/></span></h3>

  <div class="relative grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-0 z-10 w-full mt-12 mx-auto">
    
    <!-- Central Vertical Divider (Desktop only) -->
    <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-0.5 bg-gray-200 dark:bg-gray-800 transform -translate-x-1/2"></div>
    
    <!-- Left Column: Education -->
    <div class="split-col-left relative flex flex-col md:pr-12 md:text-right space-y-12">
      <!-- Mobile Timeline Line -->
      <div class="md:hidden absolute left-2 top-8 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-800"></div>

      <h4 class="text-xl font-jetbrains font-bold text-slate-500 dark:text-gray-400 uppercase tracking-widest pl-8 md:pl-0">Education</h4>
      
      <!-- Education Item 1 -->
      <div class="relative pl-8 md:pl-0">
        <!-- Node Dot -->
        <div class="absolute left-[3px] md:left-auto md:-right-[54px] top-2 w-3 h-3 rounded-full bg-cyber-citrus shadow-[0_0_10px_rgba(204,255,0,0.4)]"></div>
        
        <h3 class="text-2xl sm:text-3xl font-bold text-black dark:text-white mb-1">Lovely Professional University</h3>
        <p class="text-lg text-slate-700 dark:text-gray-300 font-medium">B.Tech CSE</p>
        <span class="text-xs font-jetbrains uppercase tracking-widest text-cyber-citrus mt-2 inline-block">2023 - 2027</span>
      </div>

      <!-- Education Item 2 -->
      <div class="relative pl-8 md:pl-0 pt-4">
        <!-- Node Dot -->
        <div class="absolute left-[3px] md:left-auto md:-right-[54px] top-6 w-3 h-3 rounded-full bg-cyber-citrus shadow-[0_0_10px_rgba(204,255,0,0.4)]"></div>
        
        <h3 class="text-2xl sm:text-3xl font-bold text-black dark:text-white mb-1">D.A.V Public School</h3>
        <p class="text-lg text-slate-700 dark:text-gray-300 font-medium">Senior Secondary: 85%</p>
        <span class="text-xs font-jetbrains uppercase tracking-widest text-cyber-citrus mt-2 inline-block">2021 - 2022</span>
      </div>
      <!-- Education Item 2 -->
      <div class="relative pl-8 md:pl-0 pt-4">
        <!-- Node Dot -->
        <div class="absolute left-[3px] md:left-auto md:-right-[54px] top-6 w-3 h-3 rounded-full bg-cyber-citrus shadow-[0_0_10px_rgba(204,255,0,0.4)]"></div>
        
        <h3 class="text-2xl sm:text-3xl font-bold text-black dark:text-white mb-1">D.A.V Public School</h3>
        <p class="text-lg text-slate-700 dark:text-gray-300 font-medium">Secondary: 92%</p>
        <span class="text-xs font-jetbrains uppercase tracking-widest text-cyber-citrus mt-2 inline-block">2019 - 2020</span>
      </div>
    </div>
    

    <!-- Right Column: Experience -->
    <div class="split-col-right relative flex flex-col md:pl-12 space-y-12 mt-12 md:mt-0 pt-8 md:pt-0">
      <!-- Mobile Timeline Line -->
      <div class="md:hidden absolute left-2 top-8 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-800"></div>

      <h4 class="text-xl font-jetbrains font-bold text-slate-500 dark:text-gray-400 uppercase tracking-widest pl-8 md:pl-0">Experience</h4>

      <!-- Experience Item 1 -->
      <div class="relative pl-8 md:pl-0">
        <!-- Node Dot -->
        <div class="absolute left-[3px] md:-left-[54px] top-2 w-3 h-3 rounded-full bg-cyber-citrus shadow-[0_0_10px_rgba(204,255,0,0.4)]"></div>
        
        <h3 class="text-2xl sm:text-3xl font-bold text-black dark:text-white mb-1">AccentureEmph</h3>
        <p class="text-lg text-slate-700 dark:text-gray-300 font-medium">Content Manager</p>
        <p class="text-sm sm:text-base text-slate-600 dark:text-gray-400 mt-3 leading-relaxed max-w-sm">
          Leading <span class="text-black dark:text-white font-medium">Digital Strategy & Communication</span> along with strategic <span class="text-black dark:text-white font-medium">Event Planning</span> initiatives.
        </p>
        <span class="text-xs font-jetbrains uppercase tracking-widest text-cyber-citrus mt-4 inline-block">2023 - 2024</span>
      </div>

    </div>
  </div>
</section>

<style>
  .split-col-left {
    opacity: 0;
    transform: translateX(-60px);
  }
  .split-col-right {
    opacity: 0;
    transform: translateX(60px);
  }
</style>
